# Supabase Edge Functions — environment template
# Lokaal: kopieer dit bestand naar `supabase/functions/.env` en vul in.
# Productie: upload met `supabase secrets set --env-file supabase/functions/.env`
# Dit bestand is committed; `.env` is gitignored.

# ---------------------------------------------------------------------
# Lightspeed eCom (Floorpassion) — fase 1: orders inlezen
# ---------------------------------------------------------------------
# Twee aparte webshops (NL + DE), beide orders landen onder dezelfde
# verzameldebiteur in RugFlow (FLOORPASSION_DEBITEUR_NR).
#
# Cluster-URL formaat EU1: https://api.webshopapp.com/{taalcode}/
# Auth: HTTP Basic (key:secret). Webhook-signature: MD5(payload + secret).

# Nederlandse webshop (floorpassion.nl / .webshopapp.com)
LIGHTSPEED_NL_API_KEY=
LIGHTSPEED_NL_API_SECRET=
LIGHTSPEED_NL_CLUSTER_URL=https://api.webshopapp.com/nl/

# Duitse webshop (floorpassion.de)
LIGHTSPEED_DE_API_KEY=
LIGHTSPEED_DE_API_SECRET=
LIGHTSPEED_DE_CLUSTER_URL=https://api.webshopapp.com/de/

# Verzameldebiteur in RugFlow waaronder alle webshop-orders landen.
# Eén debiteuren-rij "Floorpassion" — vul debiteur_nr in na aanmaken.
FLOORPASSION_DEBITEUR_NR=260000

# ---------------------------------------------------------------------
# HST vervoerder API (logistiek-module) — PRODUCTIE sinds 2026-06-17
# ---------------------------------------------------------------------
# Plan: docs/superpowers/plans/2026-05-01-logistiek-hst-api-koppeling.md
# Auth: HTTP Basic. Live-rondreis ACCP bevestigd 2026-05-27 (HTTP 201);
# productie-cutover 2026-06-17 (mig 417). Acceptatie-host was
# accp.hstonline.nl, productie-host is portal.hstonline.nl.
# Wachtwoord NIET committen — leeg laten en in Supabase dashboard secrets
# zetten. Username/CustomerID zijn gelijk in acceptatie en productie:
#   HST_API_USERNAME=karpi_array1_api_user
#   HST_API_CUSTOMER_ID=038267
# Wachtwoord apart in de password-manager.

HST_API_BASE_URL=https://portal.hstonline.nl/rest/api/v1
HST_API_USERNAME=
HST_API_WACHTWOORD=
HST_API_CUSTOMER_ID=

# ---------------------------------------------------------------------
# Transus EDI (WebConnect API) — orders in (M10110) + berichten uit (M10100)
# ---------------------------------------------------------------------
# Plan: docs/superpowers/plans/2026-04-29-edi-transus-koppeling.md
# Endpoint (hardcoded in _shared/transus-soap.ts): https://webconnect.transus.com/exchange.asmx
# Gebruikt door edge functions transus-poll + transus-send.
#
# Credentials uit Transus Online -> Instellingen -> Communicatie ->
#   "WebConnect / Transus API" (NIET het Windows Connect-blok).
# IP-adres restrictie + Compressie MOETEN uit blijven (dynamische edge-IP's,
# ongecomprimeerde base64-payloads). Key NIET committen — leeg laten en in
# Supabase Vault / dashboard secrets zetten.

TRANSUS_CLIENT_ID=
TRANSUS_CLIENT_KEY=

# Gedeelde cron-token: beveiligt de ?token=-query van transus-poll/transus-send
# (en hst-send via header). Dezelfde waarde moet in Vault staan onder 'cron_token'
# (zie mig 305 / mig 173). Genereer een lange random string.
CRON_TOKEN=
