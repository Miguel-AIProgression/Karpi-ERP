# Supabase Edge Functions — environment template
# Lokaal: kopieer dit bestand naar `supabase/functions/.env` en vul in.
# Productie: upload met `supabase secrets set --env-file supabase/functions/.env`
# Dit bestand is committed; `.env` is gitignored.

# ---------------------------------------------------------------------
# Lightspeed eCom (Floorpassion) — fase 1: orders inlezen
# ---------------------------------------------------------------------
# Twee aparte webshops (NL + DE), beide orders landen onder dezelfde
# verzameldebiteur in RugFlow (FLOORPASSION_DEBITEUR_NR).
#
# Cluster-URL formaat EU1: https://api.webshopapp.com/{taalcode}/
# Auth: HTTP Basic (key:secret). Webhook-signature: MD5(payload + secret).

# Nederlandse webshop (floorpassion.nl / .webshopapp.com)
LIGHTSPEED_NL_API_KEY=
LIGHTSPEED_NL_API_SECRET=
LIGHTSPEED_NL_CLUSTER_URL=https://api.webshopapp.com/nl/

# Duitse webshop (floorpassion.de)
LIGHTSPEED_DE_API_KEY=
LIGHTSPEED_DE_API_SECRET=
LIGHTSPEED_DE_CLUSTER_URL=https://api.webshopapp.com/de/

# Verzameldebiteur in RugFlow waaronder alle webshop-orders landen.
# Eén debiteuren-rij "Floorpassion" — vul debiteur_nr in na aanmaken.
FLOORPASSION_DEBITEUR_NR=260000
